<main>

  <section class="hero">
    <div class="wrap" style="display:grid;grid-template-columns:1.1fr .9fr;gap:48px;align-items:center;">
      <div>
        <p class="eyebrow">Est. Rahim Yar Khan · Punjab, Pakistan</p>
        <h1>A book lane on every street corner.</h1>
        <p class="lede">Booklane RYK sets up small free libraries, reading circles and writing workshops across our city — and gives student writers a real audience for their essays and stories.</p>
        <div style="display:flex;gap:14px;flex-wrap:wrap;margin-top:28px;">
          <a href="donate.html" class="btn btn-primary">Support a Lane</a>
          <a href="submit.html" class="btn btn-ghost">Submit Your Writing</a>
        </div>
      </div>
      <div class="hero-lane" aria-hidden="true">
        <div class="lane-block"><span>ABOUT</span></div>
        <div class="lane-block"><span>MISSION</span></div>
        <div class="lane-block"><span>DONATE</span></div>
        <div class="lane-block"><span>WRITE</span></div>
        <div class="lane-block"><span>GALLERY</span></div>
        <div class="lane-block"><span>READ</span></div>
      </div>
    </div>
  </section>

  <section class="section-alt">
    <div class="wrap">
      <p class="eyebrow">What we run</p>
      <h2>Three shelves, one lane.</h2>
      <div class="grid grid-3" style="margin-top:32px;">
        <div class="card raised">
          <p class="callnumber">028.9 LAN</p>
          <h3>Book Lanes</h3>
          <p>Small weatherproof book boxes placed on street corners, at bus stops and outside shops — take a book, leave a book, no membership required.</p>
        </div>
        <div class="card raised">
          <p class="callnumber">808.02 WRT</p>
          <h3>Student Writing Desk</h3>
          <p>A running collection of essays, short stories and reflections written by students from schools and colleges across RYK, published on this site.</p>
        </div>
        <div class="card raised">
          <p class="callnumber">371.3 CIR</p>
          <h3>Reading Circles</h3>
          <p>Weekly get-togethers in parks, community centres and courtyards where neighbours of every age read aloud and talk about what they've read.</p>
        </div>
      </div>
    </div>
  </section>

  <section>
    <div class="wrap" style="display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center;">
      <div>
        <p class="eyebrow">Since we started</p>
        <h2>Small numbers, real ones.</h2>
        <p class="lede">We're a volunteer-run initiative, not a large NGO. These figures are counted by hand at every lane, every term.</p>
      </div>
      <div class="grid grid-2">
        <div class="card">
          <h3 style="font-size:2.2rem;color:var(--maroon);">14</h3>
          <p style="margin:0;">book lanes standing across the city</p>
        </div>
        <div class="card">
          <h3 style="font-size:2.2rem;color:var(--teal);">210+</h3>
          <p style="margin:0;">student pieces published to date</p>
        </div>
        <div class="card">
          <h3 style="font-size:2.2rem;color:var(--marigold);">9</h3>
          <p style="margin:0;">partner schools and colleges</p>
        </div>
        <div class="card">
          <h3 style="font-size:2.2rem;color:var(--ink);">100%</h3>
          <p style="margin:0;">volunteer-run, no paid staff</p>
        </div>
      </div>
    </div>
  </section>

  <section class="section-ink">
    <div class="wrap" style="display:flex;justify-content:space-between;align-items:center;gap:24px;flex-wrap:wrap;">
      <div>
        <p class="eyebrow">Get involved</p>
        <h2 style="margin:0;">Read something. Write something. Fund something.</h2>
      </div>
      <div style="display:flex;gap:14px;flex-wrap:wrap;">
        <a href="submit.html" class="btn btn-marigold">Submit Writing</a>
        <a href="donate.html" class="btn" style="border-color:var(--paper);color:var(--paper);">Donate</a>
      </div>
    </div>
  </section>

